{
  "intents": [
    {
      "tag": "help",
      "patterns": [
        "помощ",
        "help",
        "какво можеш",
        "команди"
      ],
      "responses": [
        "Налични команди:\n── Клубове ──\n  Добави клуб <име>\n  Покажи всички клубове / списък клубове\n  Изтрий клуб <име/id>\n  Промени клуб <име/id> на <ново име>\n── Играчи ──\n  Добави играч <име> в <клуб> позиция <GK|DF|MF|FW> номер <число>\n  Покажи играчи на <клуб>\n  Смени номер на <играч> на <число>\n  Смени статус на <играч> на <статус>\n  Изтрий играч <име>\n── Други ──\n  помощ / help\n  изход / exit"
      ]
    },
    {
      "tag": "exit",
      "patterns": [
        "изход",
        "exit",
        "край",
        "quit",
        "излез",
        "довиждане"
      ],
      "responses": [
        "Довиждане!"
      ]
    },
    {
      "tag": "add_club",
      "patterns": [
        "(?:добави|създай|нов|регистрирай)\\s+(?:клуб|отбор)\\s+(.+)",
        "(?:добавяне|създаване)\\s+(?:на\\s+)?(?:клуб|отбор)\\s+(.+)"
      ],
      "responses": [
        "Клубът е добавен."
      ]
    },
    {
      "tag": "list_clubs",
      "patterns": [
        "(?:покажи|списък|изведи|лист|всички)\\s+(?:всички\\s+)?(?:клубове|клуб|отбори|отбор)",
        "list\\s+(?:all\\s+)?(?:clubs|teams)"
      ],
      "responses": [
        "Списък на клубовете:"
      ]
    },
    {
      "tag": "delete_club",
      "patterns": [
        "(?:изтрий|премахни|отстрани|изтриване\\s+на)\\s+(?:клуб|отбор)\\s+(.+)",
        "(?:delete|remove)\\s+(?:club|team)\\s+(.+)"
      ],
      "responses": [
        "Клубът е изтрит."
      ]
    },
    {
      "tag": "update_club",
      "patterns": [
        "(?:промени|преименувай|актуализирай|обнови)\\s+(?:клуб|отбор)\\s+(.+?)\\s+(?:на|в)\\s+(.+)",
        "(?:update|rename)\\s+(?:club|team)\\s+(.+?)\\s+(?:to|as)\\s+(.+)"
      ],
      "responses": [
        "Клубът е обновен."
      ]
    },
    {
      "tag": "add_player",
      "patterns": [
        "(?:добави|създай|нов|регистрирай)\\s+(?:играч|футболист)\\s+(.+?)\\s+в\\s+(.+?)\\s+позиция\\s+(\\w+)\\s+номер\\s+(\\d+)",
        "(?:add|register)\\s+(?:player|footballer)\\s+(.+?)\\s+(?:to|in)\\s+(.+?)\\s+position\\s+(\\w+)\\s+number\\s+(\\d+)"
      ],
      "responses": [
        "Играчът е добавен."
      ]
    },
    {
      "tag": "list_players",
      "patterns": [
        "(?:покажи|списък|изведи|лист|всички)\\s+(?:играчи|футболисти|играч)\\s+(?:на|от|в)\\s+(.+)",
        "(?:list|show|all)\\s+(?:players|footballers)\\s+(?:of|from|in)\\s+(.+)"
      ],
      "responses": [
        "Списък на играчите:"
      ]
    },
    {
      "tag": "update_player_number",
      "patterns": [
        "(?:смени|промени|обнови)\\s+номер\\s+(?:на\\s+)?(.+?)\\s+на\\s+(\\d+)",
        "(?:change|update)\\s+number\\s+(?:of\\s+)?(.+?)\\s+(?:to|на)\\s+(\\d+)"
      ],
      "responses": [
        "Номерът е сменен."
      ]
    },
    {
      "tag": "update_player_status",
      "patterns": [
        "(?:смени|промени|обнови)\\s+статус\\s+(?:на\\s+)?(.+?)\\s+на\\s+(.+)",
        "(?:change|update)\\s+status\\s+(?:of\\s+)?(.+?)\\s+(?:to|на)\\s+(.+)"
      ],
      "responses": [
        "Статусът е сменен."
      ]
    },
    {
      "tag": "delete_player",
      "patterns": [
        "(?:изтрий|премахни|отстрани|изтриване\\s+на)\\s+(?:играч|футболист)\\s+(.+)",
        "(?:delete|remove)\\s+(?:player|footballer)\\s+(.+)"
      ],
      "responses": [
        "Играчът е изтрит."
      ]
    },
    {
      "tag": "unknown",
      "patterns": [],
      "responses": [
        "Не разпознах командата. Напишете 'помощ' за наличните команди."
      ]
    }
  ]
}
