{
  "intents": [
    {
      "tag": "help",
      "patterns": [
        "помощ",
        "help",
        "какво можеш",
        "команди",
        "помощ"
      ],
      "responses": [
        "Налични команди:\n- Добави клуб <име> — добавя нов клуб\n- Покажи всички клубове / списък клубове — преглед на клубовете\n- Изтрий клуб <име/id> — изтрива клуб\n- Промени клуб <име/id> на <ново име> — преименува клуб\n- помощ / help — тази помощ\n- изход / exit — изход от програмата"
      ]
    },
    {
      "tag": "exit",
      "patterns": [
        "изход",
        "exit",
        "край",
        "quit",
        "излез",
        "довиждане"
      ],
      "responses": [
        "Довиждане!"
      ]
    },
    {
      "tag": "add_club",
      "patterns": [
        "(?:добави|създай|нов|регистрирай)\\s+(?:клуб|отбор)\\s+(.+)",
        "(?:добавяне|създаване)\\s+(?:на\\s+)?(?:клуб|отбор)\\s+(.+)"
      ],
      "responses": [
        "Клубът е добавен."
      ]
    },
    {
      "tag": "list_clubs",
      "patterns": [
        "(?:покажи|списък|изведи|лист|всички)\\s+(?:всички\\s+)?(?:клубове|клуб|отбори|отбор)",
        "list\\s+(?:all\\s+)?(?:clubs|teams)"
      ],
      "responses": [
        "Списък на клубовете:"
      ]
    },
    {
      "tag": "delete_club",
      "patterns": [
        "(?:изтрий|премахни|отстрани|изтриване\\s+на)\\s+(?:клуб|отбор)\\s+(.+)",
        "(?:delete|remove)\\s+(?:club|team)\\s+(.+)"
      ],
      "responses": [
        "Клубът е изтрит."
      ]
    },
    {
      "tag": "update_club",
      "patterns": [
        "(?:промени|преименувай|актуализирай|обнови)\\s+(?:клуб|отбор)\\s+(.+?)\\s+(?:на|в)\\s+(.+)",
        "(?:update|rename)\\s+(?:club|team)\\s+(.+?)\\s+(?:to|as)\\s+(.+)"
      ],
      "responses": [
        "Клубът е обновен."
      ]
    },
    {
      "tag": "unknown",
      "patterns": [],
      "responses": [
        "Не разпознах командата. Напишете 'помощ' за наличните команди."
      ]
    }
  ]
}
